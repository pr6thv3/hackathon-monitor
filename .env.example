# Environment variables for local development
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# Gemini AI (get from https://aistudio.google.com/)
GEMINI_API_KEY=your-gemini-key-here

# Telegram Bot (get token from @BotFather, chat ID from @userinfobot)
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# VIT EventHub login (your VIT student credentials)
VIT_USERNAME=your-vit-reg-number-or-email
VIT_PASSWORD=your-vit-password
